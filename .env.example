TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_ALLOWED_USER_ID=123456789
TELEGRAM_CHAT_ID=-1001234567890
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-replace-me
# 선택: 추가 계정 토큰. 기본 토큰이 한도(utilization 100% 또는 rate-limit 오류)에
# 도달하면 다음 세션부터 자동으로 다음 토큰을 사용한다(한도 초기화 시각까지 봉인).
# 각 계정에서 `claude setup-token`으로 생성한 값을 넣는다.
# CLAUDE_CODE_OAUTH_TOKEN_2=sk-ant-oat01-replace-me
# CLAUDE_CODE_OAUTH_TOKEN_3=sk-ant-oat01-replace-me
DATABASE_PATH=./data/state.sqlite
PROJECTS_PATH=./projects.json
APPROVAL_TIMEOUT_MINUTES=30
STATUS_DEBOUNCE_MS=2500
MCP_TOOL_TIMEOUT_SECONDS=60
MCP_MAX_ATTEMPTS=3
CODEX_MCP_TIMEOUT_MINUTES=30
CODEX_MCP_HEARTBEAT_SECONDS=60
# 장기 실행 MCP 서버(쉼표 구분, 소문자). 여기 들어간 서버는 60초 컷 대신
# CODEX_MCP_TIMEOUT_MINUTES 타임아웃 + CODEX_MCP_HEARTBEAT_SECONDS 주기 진행 알림을 받는다.
LONG_RUNNING_MCP_SERVERS=codex,obsidian
# 턴 유휴 워치독: 스트림이 이 시간 넘게 완전 침묵하면 먹통으로 보고 턴을 중단한다.
# 모든 MCP 서버에 균일 적용되는 backstop. 실제 적용값은 codex 타임아웃·승인
# 타임아웃보다 항상 5분 이상 크도록 자동 클램프되어 정상 장기작업을 오인하지 않는다.
TURN_IDLE_TIMEOUT_MINUTES=35
# Claude가 장기 메모리를 읽고 쓸 디렉터리. 기본값은 ~/.claude/memory
CLAUDE_MEMORY_DIR=~/.claude/memory
# CLAUDE_CODE_EXECUTABLE=/Users/your-name/.local/bin/claude
