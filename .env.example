# =============================================================================
# ChatKJB — 로컬 설정 예제
# 사용: cp .env.example .env && chmod 600 .env
#       또는 npm run setup
# .env 는 Git에 올리지 않습니다. 값은 모두 본인 계정·본인 경로로 채우십시오.
# =============================================================================

# --- 필수: Telegram ---
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_ALLOWED_USER_ID=123456789
TELEGRAM_CHAT_ID=-1001234567890
# 기본값 auto. 특정 호스트의 IPv4/IPv6 경로에 문제가 있을 때만 4 또는 6으로 고정
TELEGRAM_IP_FAMILY=auto
# 여러 사용자 허용 시 (단일 ID 대신 또는 함께 사용 가능)
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
# Telegram 앱에서 직접 지운 topic을 MTProto로 정확히 감지할 때만 둘 다 설정
# https://my.telegram.org/apps 에서 발급하며 API hash는 비밀로 취급
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
# TELEGRAM_MTPROTO_SESSION_PATH=./data/telegram-mtproto.session
# 선택: ChatKJB Terminal 전용 사용자 세션. 위 MTProto 세션·DB와 반드시 다른 파일이어야 함
# TELEGRAM_GUI_SESSION_PATH=./data/telegram-gui.session

# --- AI 제공자 인증: Claude/Codex/Antigravity/Grok 중 하나 이상 필수 ---
# Claude를 사용할 때만 `claude setup-token` 또는 npm run auth:setup 으로 발급
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-replace-me
# 선택: 추가 계정 토큰 (한도 도달 시 다음 세션부터 전환)
# CLAUDE_CODE_OAUTH_TOKEN_2=sk-ant-oat01-replace-me
# CLAUDE_CODE_OAUTH_TOKEN_3=sk-ant-oat01-replace-me

# --- 경로 (기본값으로 충분한 경우가 많음) ---
# 미설정 시 운영체제 현지 시간대 사용. 다른 시간대로 고정할 때만 IANA 이름 지정
# TZ=Asia/Seoul
# 날짜·숫자 표시 로캘(봇 UI 문구 자체는 한국어)
# CHATKJB_LOCALE=ko-KR
DATABASE_PATH=./data/state.sqlite
PROJECTS_PATH=./projects.json
APPROVAL_TIMEOUT_MINUTES=30
STATUS_DEBOUNCE_MS=2500
MCP_TOOL_TIMEOUT_SECONDS=60
MCP_MAX_ATTEMPTS=3

# --- 선택: CLI 실행 파일 (PATH에 있으면 생략 가능) ---
# CLAUDE_CODE_EXECUTABLE=~/.local/bin/claude
# CODEX_EXECUTABLE=/opt/homebrew/bin/codex
# AGY_EXECUTABLE=~/.local/bin/agy
# GROK_EXECUTABLE=~/.local/bin/grok
# GROK_MODEL=grok-4.5

# --- 선택: Codex 다중 계정 ---
# 각 디렉터리에서 1회: CODEX_HOME=<경로> codex login
# 미설정 시 단일 계정(CODEX_HOME 또는 ~/.codex)
# CODEX_ACCOUNT_HOMES=~/.codex,~/.codex-acct-b
CODEX_MCP_TIMEOUT_MINUTES=30
# Provider 턴의 절대 시간 제한(0이면 무제한)
PROVIDER_TURN_TIMEOUT_MINUTES=0
CODEX_MCP_HEARTBEAT_SECONDS=60
LONG_RUNNING_MCP_SERVERS=codex,obsidian
TURN_IDLE_TIMEOUT_MINUTES=35

# --- 선택: 장기 기억 / 위키 ---
# 기본 메모리 디렉터리
CLAUDE_MEMORY_DIR=~/.claude/memory
# 미설정 시 마운트된 볼륨(/Volumes/*/LLM-Wiki)과 CloudStorage에서 자동 탐색한다.
# 자동 탐색으로 찾지 못하는 위치에 둔 경우에만 아래를 지정한다.
# LLM_WIKI_ROOT=/absolute/path/to/LLM-Wiki
# 설정하면 /compile 성공 뒤 해당 스크립트를 --deploy로 실행한다(절대경로만 허용).
# KJB_WIKI_POST_COMPILE_SCRIPT=/absolute/path/to/tools/kjb_wiki_post_compile.sh
# CHATKJB_LOG_ROOT=~/Library/Logs

# --- 선택: agy/Grok에 노출할 MCP (설치·인증은 각자) ---
# 기본값에는 CNN Fear & Greed 조회를 제공하는 price-feed가 포함됩니다.
# 예: AGY_MCP_SERVERS=llm-wiki,obsidian,outlook,peekaboo,playwright,price-feed,literature-evidence,scihub
# AGY_MCP_SERVERS=
# 예: GROK_MCP_SERVERS=llm-wiki,obsidian,gmail,outlook,peekaboo,playwright,price-feed,literature-evidence,scihub
# GROK_MCP_SERVERS=
# korean-law 사용 시 키는 코드가 아닌 시크릿 파일에:
#   ~/.claude/shared-resources/secrets/korean-law.env  →  LAW_OC=your-oc-key

# --- 선택: 로컬 음성 받아쓰기(STT) ---
# brew install whisper-cpp ffmpeg 및 모델 준비가 끝난 뒤에만 켜십시오.
STT_ENABLED=false
STT_MODEL_PATH=~/.local/share/whisper-models/ggml-large-v3.bin
STT_LANGUAGE=ko
# STT_PROMPT=ChatKJB, Claude, Codex, git, CRISPR
# STT_WHISPER_CLI=/opt/homebrew/bin/whisper-cli
# STT_FFMPEG=/opt/homebrew/bin/ffmpeg
# STT_THREADS=8
# STT_TIMEOUT_SECONDS=300

# --- 선택: 개인 백업 미러 (일반 설치에 불필요, 쓰는 사람만 설정) ---
# CloudStorage/rsync 미러 대상 절대 경로
# CHATKJB_MIRROR_DEST=~/Library/CloudStorage/SynologyDrive-ACCOUNT/AI/ChatKJB
# NAS tar-over-SSH 미러
# CHATKJB_NAS_SSH=user@nas-host
# CHATKJB_NAS_PORT=22
# CHATKJB_NAS_REMOTE_DIR=$HOME/backups
