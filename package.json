{
  "name": "telegram-claude-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:setup": "bash scripts/setup-oauth-token.sh",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "launchd:install": "node scripts/install-launch-agent.mjs",
    "launchd:restart": "node scripts/restart-launch-agent.mjs",
    "prism": "scripts/prismctl",
    "prism:block-status": "scripts/prismctl block-status",
    "prism:status": "scripts/prismctl status",
    "start": "node dist/index.js",
    "transcripts:dump": "node scripts/dump-transcripts.mjs",
    "transcripts:install-agent": "node scripts/install-transcript-dump-agent.mjs",
    "test": "vitest run",
    "test:agy-live": "vitest run tests/agy-live.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.174",
    "@openai/codex-sdk": "^0.139.0",
    "better-sqlite3": "12.10.0",
    "dotenv": "17.2.3",
    "grammy": "1.43.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.15.29",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
